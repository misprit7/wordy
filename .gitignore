!bin/cli/
!bin/cli/**

# IDE / editor
.vs/
.vscode/
*.code-workspace
*.sln.iml
*.user
*.suo
*.userprefs

# NuGet
*.nupkg
*.snupkg

# OS / temp
~$*
*~
*.tmp
.DS_Store
Thumbs.db

# Wordy project-specific
docx/generated/*
!docx/generated/.gitkeep
web/wwwroot/lib/*.bin
web/wwwroot/examples/
