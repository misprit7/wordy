@page "/"
@using web.Services
@inject WordyCompiler Compiler

<div class="app-container">
    <!-- Title Bar -->
    <div class="title-bar">
        <div class="title-bar-icon">W</div>
        <div class="quick-access">
            <button class="qa-btn" title="Save">&#128190;</button>
            <button class="qa-btn" title="Undo">&#8630;</button>
            <button class="qa-btn" title="Redo">&#8631;</button>
        </div>
        <div class="title-bar-text">Wordy &mdash; Online Compiler</div>
        <div class="title-bar-buttons">
            <button class="title-bar-btn">&#8211;</button>
            <button class="title-bar-btn">&#9633;</button>
            <button class="title-bar-btn close">&#10005;</button>
        </div>
    </div>

    <!-- Ribbon Tabs -->
    <div class="ribbon-tabs">
        <button class="ribbon-tab file-tab">File</button>
        <button class="ribbon-tab @(activeTab == "home" ? "active" : "")" @onclick='() => activeTab = "home"'>Home</button>
        <button class="ribbon-tab @(activeTab == "compiler" ? "active" : "")" @onclick='() => activeTab = "compiler"'>Compiler</button>
        <button class="ribbon-tab">Insert</button>
        <button class="ribbon-tab">Design</button>
        <button class="ribbon-tab">Layout</button>
        <button class="ribbon-tab">References</button>
        <button class="ribbon-tab">Review</button>
        <button class="ribbon-tab">View</button>
    </div>

    <!-- Ribbon Panel -->
    <div class="ribbon-panel">
        @if (activeTab == "compiler")
        {
            <div class="ribbon-group">
                <div class="ribbon-group-content">
                    <label class="ribbon-btn upload-btn" for="docxUpload">
                        <span class="ribbon-btn-icon">&#x1F4C4;</span>
                        <span>Upload<br/>.docx</span>
                    </label>
                    <InputFile id="docxUpload" OnChange="HandleFileUpload" accept=".docx" style="display:none" />
                </div>
                <span class="ribbon-group-label">File</span>
            </div>
            <div class="ribbon-group">
                <div class="ribbon-group-content">
                    <button class="ribbon-btn @(isCompiling ? "disabled" : "")" @onclick="RunCompiler" disabled="@(uploadedFile == null || isCompiling)">
                        <span class="ribbon-btn-icon">&#x25B6;</span>
                        <span>@(isCompiling ? "Running..." : "Run")</span>
                    </button>
                </div>
                <span class="ribbon-group-label">Execute</span>
            </div>
            <div class="ribbon-group">
                <div class="ribbon-group-content file-info">
                    @if (uploadedFile != null)
                    {
                        <span class="file-name">@uploadedFile.Name</span>
                        <span class="file-size">@FormatSize(uploadedFile.Size)</span>
                    }
                    else
                    {
                        <span class="file-hint">No file uploaded</span>
                    }
                </div>
                <span class="ribbon-group-label">Document</span>
            </div>
        }
        else
        {
            <!-- Word-style formatting ribbon (decorative) -->
            <div class="ribbon-group">
                <div class="ribbon-group-content">
                    <div class="font-preview">
                        <span style="font-family:'Courier New';font-size:13px;">Courier New</span>
                        <span style="color:#999;font-size:10px;">&#9660;</span>
                    </div>
                    <div class="font-size-box">12</div>
                </div>
                <div class="ribbon-group-content">
                    <div class="format-buttons">
                        <button class="fmt-btn" title="Bold = Bracket"><b>B</b></button>
                        <button class="fmt-btn" title="Italic = String Literal"><i>I</i></button>
                        <button class="fmt-btn" style="text-decoration:underline;" title="Underline">U</button>
                        <button class="fmt-btn">x<sup style="font-size:8px;">2</sup></button>
                        <button class="fmt-btn">x<sub style="font-size:8px;">2</sub></button>
                    </div>
                </div>
                <span class="ribbon-group-label">Font = Types &amp; Casting</span>
            </div>

            <div class="ribbon-group">
                <div class="ribbon-group-content">
                    <div style="display:flex;flex-direction:column;gap:2px;">
                        <button class="ribbon-btn ribbon-btn-sm"><span class="ribbon-btn-icon">&#8592;</span> Left</button>
                        <button class="ribbon-btn ribbon-btn-sm"><span class="ribbon-btn-icon">&#8594;</span> Right = Return</button>
                        <button class="ribbon-btn ribbon-btn-sm"><span class="ribbon-btn-icon">&#8596;</span> Center</button>
                    </div>
                </div>
                <span class="ribbon-group-label">Paragraph</span>
            </div>

            <div class="ribbon-group">
                <div class="ribbon-group-content">
                    <button class="ribbon-btn">
                        <span class="ribbon-btn-icon" style="font-size:18px;font-weight:700;">H1</span>
                        <span>Heading</span>
                    </button>
                    <button class="ribbon-btn">
                        <span class="ribbon-btn-icon" style="font-size:14px;color:var(--text-muted);">Subtitle</span>
                        <span>Params</span>
                    </button>
                    <button class="ribbon-btn">
                        <span class="ribbon-btn-icon" style="font-size:28px;line-height:0.8;">D</span>
                        <span>Drop Cap</span>
                    </button>
                </div>
                <span class="ribbon-group-label">Styles = Functions</span>
            </div>

            <div class="ribbon-group">
                <div class="ribbon-group-content">
                    <button class="ribbon-btn">
                        <span class="ribbon-btn-icon">&#9638;</span>
                        <span>Table</span>
                    </button>
                </div>
                <span class="ribbon-group-label">Control Flow</span>
            </div>
        }
    </div>

    @if (activeTab == "home")
    {
        <!-- Ruler -->
        <div class="ruler">
            <div class="ruler-marks">
                <span class="ruler-mark">1</span><span class="ruler-mark">2</span>
                <span class="ruler-mark">3</span><span class="ruler-mark">4</span>
                <span class="ruler-mark">5</span><span class="ruler-mark">6</span>
                <span class="ruler-mark">7</span><span class="ruler-mark">8</span>
                <span class="ruler-mark">9</span><span class="ruler-mark">10</span>
                <span class="ruler-mark">11</span><span class="ruler-mark">12</span>
            </div>
        </div>
    }

    <!-- Main Content -->
    <div class="main-area">
        @if (activeTab == "compiler")
        {
            <div class="panels">
                <!-- C# Source Panel -->
                <div class="panel">
                    <div class="panel-header">Generated C#</div>
                    <div class="panel-body code">
                        <pre>@(result?.CSharpSource ?? "// Upload a .docx file and click Run")</pre>
                    </div>
                </div>

                <!-- Console Output Panel -->
                <div class="panel">
                    <div class="panel-header">Console Output</div>
                    <div class="panel-body console @(result?.Success == false ? "has-error" : "")">
                        @if (result != null)
                        {
                            @if (result.Output != null)
                            {
                                <pre class="output">@result.Output</pre>
                            }
                            @if (result.Error != null)
                            {
                                <pre class="error">@result.Error</pre>
                            }
                        }
                        else if (isCompiling)
                        {
                            <div class="loading">Compiling...</div>
                        }
                    </div>
                </div>
            </div>
        }
        else
        {
            <iframe src="docs/index.html?embedded=true" class="docs-frame"></iframe>
        }
    </div>

    <!-- Status Bar -->
    <div class="status-bar">
        <div class="status-left">
            @if (activeTab == "compiler")
            {
                <span>@statusText</span>
            }
            else
            {
                <span>Page 1 of 1</span>
                <span class="status-separator">Words: &infin;</span>
                <span class="status-separator">English (United States)</span>
            }
        </div>
        <div class="status-right-area">
            @if (activeTab == "home")
            {
                <span>&#128196; Print Layout</span>
                <span class="status-separator">100%</span>
            }
            else
            {
                <span>Wordy Compiler v1.0</span>
            }
        </div>
    </div>
</div>

@code {
    private string activeTab = "compiler";
    private IBrowserFile? uploadedFile;
    private CompilationResult? result;
    private bool isCompiling;
    private string statusText = "Ready";

    private void HandleFileUpload(InputFileChangeEventArgs e)
    {
        uploadedFile = e.File;
        result = null;
        statusText = $"Loaded: {uploadedFile.Name}";
    }

    private async Task RunCompiler()
    {
        if (uploadedFile == null || isCompiling) return;

        isCompiling = true;
        result = null;
        statusText = "Compiling...";
        StateHasChanged();

        await Task.Yield(); // Let UI update

        using var stream = uploadedFile.OpenReadStream(maxAllowedSize: 10 * 1024 * 1024);
        using var ms = new MemoryStream();
        await stream.CopyToAsync(ms);
        ms.Position = 0;

        result = await Compiler.CompileAndRunAsync(ms);
        isCompiling = false;
        statusText = result.Success ? "Compiled and executed successfully" : "Compilation failed";
    }

    private string FormatSize(long bytes)
    {
        if (bytes < 1024) return $"{bytes} B";
        if (bytes < 1024 * 1024) return $"{bytes / 1024.0:F1} KB";
        return $"{bytes / (1024.0 * 1024.0):F1} MB";
    }
}
