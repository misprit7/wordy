@page "/"
@using web.Services
@inject WordyCompiler Compiler
@inject IJSRuntime JS

<div class="app-container">
    <!-- Title Bar -->
    <div class="title-bar">
        <div class="title-bar-icon">W</div>
        <div class="quick-access">
            <button class="qa-btn" title="Save">&#128190;</button>
            <button class="qa-btn" title="Undo">&#8630;</button>
            <button class="qa-btn" title="Redo">&#8631;</button>
        </div>
        <div class="title-bar-text">Wordy &mdash; Online Compiler</div>
        <div class="title-bar-buttons">
            <button class="title-bar-btn">&#8211;</button>
            <button class="title-bar-btn">&#9633;</button>
            <button class="title-bar-btn close">&#10005;</button>
        </div>
    </div>

    <!-- Ribbon Tabs -->
    <div class="ribbon-tabs">
        <button class="ribbon-tab file-tab">File</button>
        <button class="ribbon-tab @(activeTab == "compiler" ? "active" : "")" @onclick='() => activeTab = "compiler"'>Compiler</button>
        <button class="ribbon-tab @(activeTab == "docs" ? "active" : "")" @onclick='() => activeTab = "docs"'>Docs</button>
    </div>

    <!-- Ribbon Panel -->
    <div class="ribbon-panel">
        @if (activeTab == "compiler")
        {
            <div class="ribbon-group">
                <div class="ribbon-group-content" style="gap:6px;">
                    <label class="ribbon-btn upload-btn" for="docxUpload" title="Upload one or more .docx files from your computer">
                        <span class="ribbon-btn-icon">&#x1F4C4;</span>
                        <span>Upload<br/>.docx</span>
                    </label>
                    <InputFile id="docxUpload" OnChange="HandleFileUpload" accept=".docx" multiple style="display:none" />
                    <div class="ribbon-separator"></div>
                    <div class="example-dropdown">
                        <select @onchange="AddExample" class="example-select">
                            <option value="">Add example...</option>
                            @foreach (var name in exampleNames)
                            {
                                <option value="@name" disabled="@uploadedFiles.ContainsKey($"{name}.docx")">@name@(uploadedFiles.ContainsKey($"{name}.docx") ? " (loaded)" : "")</option>
                            }
                        </select>
                        <button class="ribbon-btn-sm-inline" @onclick="LoadAllExamples" title="Load all example files at once">
                            All
                        </button>
                    </div>
                </div>
                <span class="ribbon-group-label">Add Files</span>
            </div>
            <div class="ribbon-group">
                <div class="ribbon-group-content">
                    <div class="file-list-panel">
                        @if (uploadedFiles.Count > 0)
                        {
                            @if (uploadedFiles.Count > 1)
                            {
                                <div class="file-list-header">
                                    <span class="file-list-label">Main:</span>
                                    <select @onchange="ChangeMainFile" class="main-file-select">
                                        @foreach (var name in uploadedFiles.Keys.OrderBy(n => n))
                                        {
                                            <option value="@name" selected="@(name == mainFileName)">@name</option>
                                        }
                                    </select>
                                </div>
                            }
                            <div class="file-chips">
                                @foreach (var name in uploadedFiles.Keys.OrderBy(n => n))
                                {
                                    <span class="file-chip @(name == mainFileName ? "file-chip-main" : "")" @onclick="() => SetMainFile(name)" title="@(name == mainFileName ? "Main file (entry point)" : "Click to set as main")">
                                        <span class="file-chip-icon">@(name == mainFileName ? "\u25B6" : "\uD83D\uDCC4")</span>
                                        @name
                                        <button class="file-chip-remove" @onclick="() => RemoveFile(name)" @onclick:stopPropagation="true" title="Remove">&#10005;</button>
                                    </span>
                                }
                            </div>
                        }
                        else
                        {
                            <span class="file-hint">No files loaded &mdash; upload .docx or add an example</span>
                        }
                    </div>
                </div>
                <span class="ribbon-group-label">Files@(uploadedFiles.Count > 0 ? $" ({uploadedFiles.Count})" : "")</span>
            </div>
            <div class="ribbon-group">
                <div class="ribbon-group-content">
                    <button class="ribbon-btn @(isCompiling ? "disabled" : "")" @onclick="RunCompiler" disabled="@(uploadedFiles.Count == 0 || isCompiling)">
                        <span class="ribbon-btn-icon">&#x25B6;</span>
                        <span>@(isCompiling ? "Running..." : "Run")</span>
                    </button>
                </div>
                <span class="ribbon-group-label">Execute</span>
            </div>
        }
        else
        {
            <!-- Navigation toggle -->
            <div class="ribbon-group" style="padding:4px 8px;">
                <div class="ribbon-group-content">
                    <button class="ribbon-btn" @onclick="ToggleDocsNav" title="Toggle navigation pane">
                        <span class="ribbon-btn-icon">&#9776;</span>
                        <span>Nav</span>
                    </button>
                </div>
            </div>
            <!-- Word-style formatting ribbon (decorative) -->
            <div class="ribbon-group">
                <div class="ribbon-group-content">
                    <div class="font-preview">
                        <span style="font-family:'Courier New';font-size:13px;">Courier New</span>
                        <span style="color:#999;font-size:10px;">&#9660;</span>
                    </div>
                    <div class="font-size-box">12</div>
                </div>
                <div class="ribbon-group-content">
                    <div class="format-buttons">
                        <button class="fmt-btn" title="Bold = Bracket"><b>B</b></button>
                        <button class="fmt-btn" title="Italic = String Literal"><i>I</i></button>
                        <button class="fmt-btn" style="text-decoration:underline;" title="Underline">U</button>
                        <button class="fmt-btn" title="Subscript = Array Access">x&#x2082;</button>
                        <button class="fmt-btn" title="Superscript = Exponentiation">x&#x00B2;</button>
                    </div>
                </div>
                <span class="ribbon-group-label">Font = Types &amp; Casting</span>
            </div>

            <div class="ribbon-group">
                <div class="ribbon-group-content">
                    <div style="display:flex;flex-direction:column;gap:2px;">
                        <button class="ribbon-btn ribbon-btn-sm"><span class="ribbon-btn-icon">&#8592;</span> Left</button>
                        <button class="ribbon-btn ribbon-btn-sm"><span class="ribbon-btn-icon">&#8594;</span> Right = Return</button>
                        <button class="ribbon-btn ribbon-btn-sm"><span class="ribbon-btn-icon">&#8596;</span> Center</button>
                    </div>
                </div>
                <span class="ribbon-group-label">Paragraph</span>
            </div>

            <div class="ribbon-group">
                <div class="ribbon-group-content">
                    <button class="ribbon-btn">
                        <span class="ribbon-btn-icon" style="font-size:18px;font-weight:700;">H1</span>
                        <span>Heading</span>
                    </button>
                    <button class="ribbon-btn">
                        <span class="ribbon-btn-icon" style="font-size:14px;color:var(--text-muted);">Subtitle</span>
                        <span>Params</span>
                    </button>
                    <button class="ribbon-btn">
                        <span class="ribbon-btn-icon" style="font-size:28px;line-height:0.8;">D</span>
                        <span>Drop Cap</span>
                    </button>
                </div>
                <span class="ribbon-group-label">Styles = Functions</span>
            </div>

            <div class="ribbon-group">
                <div class="ribbon-group-content">
                    <button class="ribbon-btn">
                        <span class="ribbon-btn-icon">&#9638;</span>
                        <span>Table</span>
                    </button>
                </div>
                <span class="ribbon-group-label">Control Flow</span>
            </div>
        }
    </div>

    @if (activeTab == "docs")
    {
        <!-- Ruler -->
        <div class="ruler">
            <div class="ruler-marks">
                <span class="ruler-mark">1</span><span class="ruler-mark">2</span>
                <span class="ruler-mark">3</span><span class="ruler-mark">4</span>
                <span class="ruler-mark">5</span><span class="ruler-mark">6</span>
                <span class="ruler-mark">7</span><span class="ruler-mark">8</span>
                <span class="ruler-mark">9</span><span class="ruler-mark">10</span>
                <span class="ruler-mark">11</span><span class="ruler-mark">12</span>
            </div>
        </div>
    }

    <!-- Main Content -->
    <div class="main-area">
        @if (activeTab == "compiler")
        {
            <div class="compiler-pages">
                <div class="compiler-page">
                    <div class="page-title">Document Preview <span class="page-title-disclaimer" title="This preview is rendered client-side using the docx-preview JavaScript library, not Microsoft Word's rendering engine. Formatting, fonts, and layout may differ from how the document appears in Word. For accurate editing and viewing, open the .docx file in Microsoft Word.">(approximate rendering)</span></div>
                    <div class="page-preview">
                        <div class="preview-placeholder" style="@(uploadedFiles.Count > 0 ? "display:none" : "")">Upload a .docx to preview</div>
                        <div id="docx-preview"></div>
                    </div>
                </div>
                <div class="compiler-page">
                    <div class="page-title">Generated C#</div>
                    <pre class="page-code">@(result?.CSharpSource ?? "// Upload a .docx file and click Run")</pre>
                </div>
                <div class="compiler-page">
                    <div class="page-title">Console Output</div>
                    <div class="page-console @(result?.Success == false ? "has-error" : "")">
                        @if (result != null)
                        {
                            @if (result.Output != null)
                            {
                                <pre class="output">@result.Output</pre>
                            }
                            @if (result.Error != null)
                            {
                                <pre class="error">@result.Error</pre>
                            }
                        }
                        else if (isCompiling)
                        {
                            <div class="compiling">Compiling...</div>
                        }
                    </div>
                </div>
            </div>
        }
        else
        {
            <iframe src="docs/index.html" class="docs-frame"></iframe>
        }
    </div>

    <!-- Status Bar -->
    <div class="status-bar">
        <div class="status-left">
            @if (activeTab == "compiler")
            {
                <span>@statusText</span>
            }
            else
            {
                <span>Page 1 of 1</span>
                <span class="status-separator">Words: &infin;</span>
                <span class="status-separator">English (United States)</span>
            }
        </div>
        <div class="status-right-area">
            @if (activeTab == "docs")
            {
                <span>&#128196; Print Layout</span>
                <span class="status-separator">100%</span>
            }
            else
            {
                <span>Wordy Compiler v1.0</span>
            }
        </div>
    </div>
</div>

@code {
    // Set at build time — changes only on rebuild, so browsers cache until then
    private static readonly string BuildVersion = typeof(Home).Assembly.GetName().Version?.ToString() ?? "0";

    private static readonly string[] exampleNames = { "Factorial", "FizzBuzz", "Fibonacci", "Comprehensive" };

    private string activeTab = "compiler";
    private Dictionary<string, byte[]> uploadedFiles = new();
    private string? mainFileName;
    private CompilationResult? result;
    private bool isCompiling;
    private string statusText = "Ready";

    [Inject] private HttpClient Http { get; set; } = default!;

    private async Task HandleFileUpload(InputFileChangeEventArgs e)
    {
        result = null;

        foreach (var file in e.GetMultipleFiles(maximumFileCount: 20))
        {
            using var stream = file.OpenReadStream(maxAllowedSize: 10 * 1024 * 1024);
            using var ms = new MemoryStream();
            await stream.CopyToAsync(ms);
            uploadedFiles[file.Name] = ms.ToArray();
        }

        // Set the main file to the first uploaded file if not already set
        if (mainFileName == null || !uploadedFiles.ContainsKey(mainFileName))
        {
            mainFileName = uploadedFiles.Keys.First();
        }

        statusText = uploadedFiles.Count == 1
            ? $"Loaded: {mainFileName}"
            : $"Loaded {uploadedFiles.Count} files (main: {mainFileName})";
        StateHasChanged();
        await Task.Yield();

        await RenderMainPreview();
    }

    private async Task AddExample(ChangeEventArgs e)
    {
        var name = e.Value?.ToString();
        if (string.IsNullOrEmpty(name)) return;

        try
        {
            var bytes = await Http.GetByteArrayAsync($"examples/{name}.docx?v={BuildVersion}");
            var fileName = $"{name}.docx";
            uploadedFiles[fileName] = bytes;

            // If this is the first file, or no main set, make it main
            if (mainFileName == null || uploadedFiles.Count == 1)
            {
                mainFileName = fileName;
            }

            result = null;
            statusText = $"Added {fileName} ({uploadedFiles.Count} files loaded, main: {mainFileName})";
            StateHasChanged();
            await Task.Yield();

            await RenderMainPreview();
        }
        catch (Exception ex)
        {
            statusText = $"Failed to load example: {ex.Message}";
        }
    }

    private async Task LoadAllExamples()
    {
        try
        {
            foreach (var name in exampleNames)
            {
                var fileName = $"{name}.docx";
                if (uploadedFiles.ContainsKey(fileName)) continue;
                var bytes = await Http.GetByteArrayAsync($"examples/{name}.docx?v={BuildVersion}");
                uploadedFiles[fileName] = bytes;
            }

            if (mainFileName == null || !uploadedFiles.ContainsKey(mainFileName))
            {
                mainFileName = uploadedFiles.Keys.First();
            }

            result = null;
            statusText = $"Loaded all examples ({uploadedFiles.Count} files, main: {mainFileName})";
            StateHasChanged();
            await Task.Yield();

            await RenderMainPreview();
        }
        catch (Exception ex)
        {
            statusText = $"Failed to load examples: {ex.Message}";
        }
    }

    private async Task SetMainFile(string name)
    {
        if (!uploadedFiles.ContainsKey(name) || name == mainFileName) return;
        mainFileName = name;
        statusText = $"Main file: {mainFileName} ({uploadedFiles.Count} files loaded)";
        StateHasChanged();
        await Task.Yield();
        await RenderMainPreview();
    }

    private async Task RenderMainPreview()
    {
        if (mainFileName != null && uploadedFiles.TryGetValue(mainFileName, out var bytes))
        {
            var base64 = Convert.ToBase64String(bytes);
            await JS.InvokeVoidAsync("renderDocxPreview", "docx-preview", base64);
        }
    }

    private async Task ChangeMainFile(ChangeEventArgs e)
    {
        var name = e.Value?.ToString();
        if (string.IsNullOrEmpty(name) || !uploadedFiles.ContainsKey(name)) return;
        await SetMainFile(name);
    }

    private async Task RemoveFile(string name)
    {
        uploadedFiles.Remove(name);

        if (uploadedFiles.Count == 0)
        {
            mainFileName = null;
            result = null;
            statusText = "Ready";
        }
        else if (name == mainFileName)
        {
            mainFileName = uploadedFiles.Keys.First();
            statusText = $"Main file: {mainFileName} ({uploadedFiles.Count} files loaded)";
            await RenderMainPreview();
        }
        else
        {
            statusText = uploadedFiles.Count == 1
                ? $"Loaded: {mainFileName}"
                : $"Main file: {mainFileName} ({uploadedFiles.Count} files loaded)";
        }
    }

    private async Task RunCompiler()
    {
        if (uploadedFiles.Count == 0 || mainFileName == null || isCompiling) return;

        isCompiling = true;
        result = null;
        statusText = "Compiling...";
        StateHasChanged();

        await Task.Yield(); // Let UI update

        var streams = new Dictionary<string, Stream>();
        foreach (var (name, bytes) in uploadedFiles)
        {
            streams[name] = new MemoryStream(bytes);
        }

        try
        {
            result = await Compiler.CompileAndRunAsync(streams, mainFileName);
        }
        finally
        {
            foreach (var s in streams.Values)
                s.Dispose();
        }

        isCompiling = false;
        statusText = result.Success ? "Compiled and executed successfully" : "Compilation failed";
    }

    private async Task ToggleDocsNav()
    {
        await JS.InvokeVoidAsync("toggleDocsNav");
    }

}
