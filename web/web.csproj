<Project Sdk="Microsoft.NET.Sdk.BlazorWebAssembly">

  <PropertyGroup>
    <TargetFramework>net8.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <PublishTrimmed>false</PublishTrimmed>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.AspNetCore.Components.WebAssembly" Version="8.0.13" />
    <PackageReference Include="Microsoft.AspNetCore.Components.WebAssembly.DevServer" Version="8.0.13" PrivateAssets="all" />
    <PackageReference Include="Microsoft.CodeAnalysis.CSharp" Version="5.3.0" />
    <PackageReference Include="DocumentFormat.OpenXml" Version="3.4.1" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="../src/wordy.csproj" />
  </ItemGroup>

  <!-- Copy WASM runtime DLLs to wwwroot/lib/ for Roslyn in-browser compilation.
       Resolves the browser-wasm runtime pack path from the SDK's known location. -->
  <Target Name="CopyWasmRoslynLibs" BeforeTargets="Build;Publish">
    <PropertyGroup>
      <_WasmPkgPath>$(NuGetPackageRoot)microsoft.netcore.app.runtime.mono.browser-wasm/$(BundledNETCoreAppPackageVersion)</_WasmPkgPath>
    </PropertyGroup>
    <ItemGroup>
      <_WasmRoslynLib Include="$(_WasmPkgPath)/runtimes/browser-wasm/lib/net8.0/mscorlib.dll" />
      <_WasmRoslynLib Include="$(_WasmPkgPath)/runtimes/browser-wasm/lib/net8.0/System.dll" />
      <_WasmRoslynLib Include="$(_WasmPkgPath)/runtimes/browser-wasm/lib/net8.0/System.Console.dll" />
      <_WasmRoslynLib Include="$(_WasmPkgPath)/runtimes/browser-wasm/lib/net8.0/System.Core.dll" />
      <_WasmRoslynLib Include="$(_WasmPkgPath)/runtimes/browser-wasm/lib/net8.0/System.Runtime.dll" />
      <_WasmRoslynLib Include="$(_WasmPkgPath)/runtimes/browser-wasm/lib/net8.0/System.Collections.dll" />
      <_WasmRoslynLib Include="$(_WasmPkgPath)/runtimes/browser-wasm/lib/net8.0/netstandard.dll" />
      <_WasmRoslynLib Include="$(_WasmPkgPath)/runtimes/browser-wasm/native/System.Private.CoreLib.dll" />
    </ItemGroup>
    <MakeDir Directories="wwwroot/lib" />
    <Copy SourceFiles="@(_WasmRoslynLib)" DestinationFolder="wwwroot/lib" SkipUnchangedFiles="true" />
    <Message Importance="high" Text="Roslyn libs: copied from $(_WasmPkgPath)" />
  </Target>

</Project>
